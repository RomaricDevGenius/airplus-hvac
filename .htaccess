RewriteEngine On
# Servir les fichiers statiques directement (éviter 502)
RewriteCond %{REQUEST_URI} ^/static/(.*)$
RewriteCond %{DOCUMENT_ROOT}/staticfiles/%1 -f
RewriteRule ^static/(.*)$ staticfiles/$1 [L]

